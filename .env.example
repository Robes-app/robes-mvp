# Required — get yours at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Airtable — airtable.com/create/tokens + base ID from your base URL
AIRTABLE_TOKEN=your_airtable_pat_here
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Cloudinary — cloudinary.com (free tier) — cloud name, API key, API secret from dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional — server port (default: 3000)
# PORT=3000
